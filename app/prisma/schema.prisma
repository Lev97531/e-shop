generator client {
  provider = "prisma-client"
  output   = "generated"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          Int     @id @default(autoincrement())
  slug        String  @unique
  name        String
  priceCents  Int
  imageUrl    String?
  description String  @default("")
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  
  emailAuth EmailAuth?
}

model EmailAuth {
  userId Int @id
  user   User @relation(fields: [userId], references: [id])
  passwordHash String
  passwordSalt String
}