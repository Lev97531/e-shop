generator client {
  provider = "prisma-client"
  output   = "generated"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  priceCents  Int
  imageUrl    String?
  description String  @default("")
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
}
