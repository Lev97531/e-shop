generator client {
  provider = "prisma-client"
  output   = "generated"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          Int     @id @default(autoincrement())
  slug        String  @unique
  name        String
  priceCents  Int
  imageUrl    String?
  description String  @default("")
  rating      Int?
  isAvailable Boolean @default(true)
  isOnSale    Boolean @default(false)
  isNew       Boolean @default(false)
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique

  emailAuth EmailAuth?
  session   Session[]
}

model EmailAuth {
  userId       Int    @id
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String
  passwordSalt String
}

model Session {
  id        String   @id @default(uuid())
  userId    Int
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
